{
  "name": "planner",
  "packageManager": "yarn@4.14.1",
  "devDependencies": {
    "@types/suncalc": "^1.9.2",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "build": "esbuild main.ts --bundle --outfile=bundle.js",
    "export": "yarn build && esbuild export.ts --bundle --platform=node --outfile=export.cjs && node export.cjs",
    "format": "prettier --write '*.{ts,html,json,mjs}'",
    "lint": "eslint '*.ts'",
    "check": "yarn format && yarn lint"
  },
  "dependencies": {
    "jspdf": "^4.2.1",
    "suncalc": "^2.0.0"
  }
}
